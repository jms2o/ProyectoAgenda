rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isValidHour(value) {
      return value is string
        && value.matches('^([01][0-9]|2[0-3]):[0-5][0-9]$');
    }

    function isValidDateISO(value) {
      return value is string
        && value.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$');
    }

    function isValidEmail(value) {
      return value is string
        && value.size() > 5
        && value.size() <= 120
        && value.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$');
    }

    function isValidPhone(value) {
      return value is string
        && value.size() >= 8
        && value.size() <= 20
        && value.matches('^[0-9+()\\-\\s]+$');
    }

    match /settings/{docId} {
      // Lectura pública solo para cargar horarios en la landing.
      allow read: if docId == "general";

      // Escritura exclusiva admin y solo con estructura esperada.
      allow write: if isAdmin()
        && docId == "general"
        && request.resource.data.keys().hasOnly(['startTime', 'endTime', 'duration'])
        && isValidHour(request.resource.data.startTime)
        && isValidHour(request.resource.data.endTime)
        && request.resource.data.duration in [30, 60, 90];
    }

    match /appointments/{appointmentId} {
      // Solo admin puede listar/leer y borrar citas.
      allow read, delete: if isAdmin();

      // Creación pública con validación estricta del payload.
      allow create: if request.resource.data.keys().hasOnly([
          'clientName',
          'clientEmail',
          'company',
          'whatsapp',
          'businessType',
          'notes',
          'date',
          'dateISO',
          'time',
          'status',
          'createdAt'
        ])
        && request.resource.data.clientName is string
        && request.resource.data.clientName.size() >= 2
        && request.resource.data.clientName.size() <= 80
        && isValidEmail(request.resource.data.clientEmail)
        && request.resource.data.company is string
        && request.resource.data.company.size() >= 2
        && request.resource.data.company.size() <= 100
        && isValidPhone(request.resource.data.whatsapp)
        && request.resource.data.businessType in ['', 'Servicios', 'Venta de productos', 'Otro']
        && request.resource.data.notes is string
        && request.resource.data.notes.size() <= 600
        && request.resource.data.date is string
        && request.resource.data.date.size() >= 6
        && request.resource.data.date.size() <= 40
        && isValidDateISO(request.resource.data.dateISO)
        && isValidHour(request.resource.data.time)
        && request.resource.data.status == 'Pendiente'
        // Exige serverTimestamp() en createdAt.
        && request.resource.data.createdAt == request.time;

      // Solo admin puede cambiar el estado y nada mas.
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['status'])
        && request.resource.data.status in ['Pendiente', 'Confirmada', 'Cancelada'];
    }
  }
}
